  "hdri_catalog": {
    "studio-hard":       "sharp single-source, minimal fill",
    "studio-soft":       "balanced 3-point with softboxes",
    "atmospheric-soft":  "omnidirectional, low contrast",
    "overcast":          "diffuse sky, no direct source",
    "sunset":            "warm directional + ambient",
    "dawn":              "cool directional + warm fill",
    "neon-night":        "moody ambient + colored point lights",
    "lab":               "cool even, scientific feel",
    "spatial-white":     "bright diffuse, visionOS aesthetic",
