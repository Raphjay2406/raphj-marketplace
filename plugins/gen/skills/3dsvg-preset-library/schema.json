{
  "$schema": "http://json-schema.org/draft-07/schema#",
  "$id": "genorah://3dsvg-presets",
  "title": "Genorah 3dsvg Preset",
  "type": "object",
  "oneOf": [
    {
      "title": "Enabled preset",
      "required": ["id", "archetype", "beat", "display_name", "text_template", "material", "animation", "depth", "intro", "export_formats", "motion_health_budget_units", "live_component_cost_kb", "offline_export_cost_kb", "notes"],
      "properties": {
        "id":              { "type": "string", "pattern": "^[a-z0-9]+_(hook|peak|close)_\\d{3}$" },
        "archetype":       { "type": "string", "minLength": 3 },
        "beat":            { "enum": ["HOOK", "PEAK", "CLOSE"] },
        "display_name":    { "type": "string", "minLength": 5 },
        "text_template":   { "type": ["string", "null"], "pattern": "^\\{[a-z_]+\\}$|^$" },
        "material":        { "enum": ["default", "plastic", "metal", "glass", "rubber", "chrome", "gold", "clay", "emissive", "holographic"] },
        "animation":       { "enum": ["none", "spin", "float", "pulse", "wobble", "spinFloat", "swing"] },
        "depth":           { "type": "number", "minimum": 0.1, "maximum": 2.0 },
        "bevel":           {
          "oneOf": [
            { "type": "null" },
            {
              "type": "object",
              "required": ["thickness", "segments"],
              "properties": {
                "thickness": { "type": "number", "minimum": 0.01, "maximum": 0.25 },
                "segments":  { "type": "integer", "minimum": 2, "maximum": 12 }
              }
            }
          ]
        },
        "color_override":  { "type": ["string", "null"], "pattern": "^(#[0-9a-fA-F]{3,8}|null)$" },
        "intro":           {
          "type": "object",
          "required": ["type", "duration"],
          "properties": {
            "type":     { "enum": ["none", "fade", "zoom"] },
            "duration": { "type": "number", "minimum": 0, "maximum": 5.0 }
          }
        },
        "export_formats":  { "type": "array", "items": { "enum": ["png-4k", "mp4-60fps", "webm-60fps", "jsx-component"] }, "minItems": 1 },
        "motion_health_budget_units": { "type": "integer", "minimum": 0, "maximum": 2 },
        "live_component_cost_kb":     { "type": "integer", "minimum": 0, "maximum": 300 },
        "offline_export_cost_kb":     { "type": "integer", "minimum": 0, "maximum": 100 },
        "notes":           { "type": "string", "minLength": 20 }
      }
    },
    {
      "title": "Disabled preset",
      "required": ["id", "archetype", "beat", "disabled", "fallback_strategy", "reason", "notes"],
      "properties": {
        "id":                { "type": "string" },
        "archetype":         { "type": "string" },
        "beat":              { "enum": ["HOOK", "PEAK", "CLOSE"] },
        "disabled":          { "const": true },
        "fallback_strategy": { "type": "string", "minLength": 10 },
        "reason":            { "type": "string", "minLength": 20 },
        "notes":             { "type": "string" }
      }
    }
  ]
}
