{
  "name": "genorah-plugin",
  "workspaces": [
    "packages/*"
  ],
  "version": "3.25.0",
  "private": true,
  "type": "module",
  "description": "Genorah Claude Code plugin — internal testing infrastructure for hooks + dashboard + skill schema validation",
  "engines": {
    "node": ">=20"
  },
  "scripts": {
    "test": "node --test tests/*.test.mjs",
    "test:watch": "node --test --watch tests/*.test.mjs",
    "lint:syntax": "node scripts/lint-syntax.mjs",
    "lint:json": "node scripts/lint-json.mjs",
    "lint:frontmatter": "node scripts/lint-frontmatter.mjs",
    "self-audit": "node scripts/self-audit.mjs --fail-on=BLOCK",
    "sync-mirror": "node scripts/sync-mirror.mjs",
    "check-mirror": "node scripts/check-mirror-parity.mjs",
    "validate": "npm run lint:syntax && npm run lint:json && npm run lint:frontmatter && npm run self-audit && npm run test",
    "prepush": "npm run check-mirror"
  },
  "devDependencies": {
    "@testing-library/dom": "^10.4.1",
    "ajv": "^8.17.1",
    "react-dom": "^19.2.5",
    "yaml": "^2.6.0"
  },
  "dependencies": {
    "globby": "^14.0.2"
  }
}
